# ============================================
# Restaurant CMS - Environment Variables
# ============================================
# Copy this file to .env and fill in values.
#   cp .env.example .env
# ============================================

# --- Backend (FastAPI) ---
DATABASE_URL=mysql+pymysql://restaurant_user:restaurant_pass@localhost:3306/restaurant_cms
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Email (Resend) ---
RESEND_API_KEY=

# --- reCAPTCHA ---
# PUBLIC_RECAPTCHA_SITE_KEY must be the same value as RECAPTCHA_SITE_KEY
PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Frontend (SvelteKit) ---
# Used at build time. Must include protocol and no trailing slash.
PUBLIC_API_URL=http://localhost:8000/api
